local aplConn, aprConn = nil, nil
local aplOn, aprOn = false, false
local aplPhase, aprPhase = 1, 1

local FSPD = 60 -- Forward speed
local RSPD = 30 -- Return speed
local L1 = POSITION_L1
local LEND = POSITION_L2
local LFINAL = POSITION_L2 -- Assume same as LEND, adjust if needed
local R1 = POSITION_R1
local REND = POSITION_R2
local RFINAL = POSITION_R2 -- Assume same as REND, adjust if needed

local cfg = { -- Config for float
	FloatPlayL = true, -- Enable float for left return
	FloatPlayR = true -- Enable float for right return
}

local function getHRP() return hrp end
local function getHum() return hum end
local RS = RunService

local function stopAutoPlayLeft()
